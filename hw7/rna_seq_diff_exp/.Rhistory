gc_content_calc(dna_seq)
gc_content_calc <- function(dna) {
bases <- strsplit(dna, "")[[1]]
gc <- sum(bases %in% c("C", "G"))
percent <- (gc / lenght(bases))* 100
return(percent)
}
dna_seq <- "AGCTAGCTAGCT"
gc_content_calc(dna_seq)
percent <- (gc / length(bases))* 100
return(percent)
